# .gitignore — Command-Center

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
out/
release/
dist/

# ── electron-builder artifacts (if they land outside release/) ────────────────
*.blockmap

# ── Environment — NEVER commit secrets ───────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Vite ─────────────────────────────────────────────────────────────────────
.vite/

# ── SQLite — local user data, never committed ─────────────────────────────────
# The live DB lives in %APPDATA%\Command-Center\ (outside the repo) so it is
# never at risk, but block any accidental copies dropped into the project tree.
*.db
*.db-shm
*.db-wal

# ── Export / backup archives — may contain personal item paths ────────────────
# ZIP exports produced by Import/Export page contain the full DB + icons.
# Never commit these — they contain your real file paths, URLs, and shortcuts.
*.zip
exports/
backups/
scripts/

# ── User data snapshots (if ever copied locally for debugging) ────────────────
userdata/
user-data/
data/

# ── Personal dev context (Claude AI session files) ──────────────────────────
claude.md
RESUME.md
PROGRESS.md

# ── Unshipped planning docs (future specs / superseded plans) ───────────────
docs/ICON_LIBRARY_GRID_REDESIGN.md
docs/ICON_SIZE_INCREASE_PLAN.md
docs/PHASE_14_PROJECT_DASHBOARD.md

# ── Temp ─────────────────────────────────────────────────────────────────────
tmp/
temp/

# ── Native module build artifacts ────────────────────────────────────────────
*.node
build/Release/
gitsync.bat
deploy-log.txt
.gitsync.lock
