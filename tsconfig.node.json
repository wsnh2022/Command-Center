{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "out",
    "baseUrl": ".",
    "paths": {
      "@electron/*": [
        "electron/*"
      ],
      "@shared/types": [
        "src/types/index.ts"
      ]
    }
  },
  "include": [
    "electron",
    "electron.vite.config.ts",
    "src/types"
  ]
}